[secret]
command = "op"

{{- $choices := list "personal" "work" -}}
{{- $hosttype := promptChoice "Setup type" $choices -}}
[data]
hosttype = {{- $hosttype | quote -}}
is_work_machine = {{- promptBool "Setup as work machine?" false -}}

[merge]
command = "git"
args = ["mergetool"]

[edit]
command = "pycharm"
args = ["-e", "--wait"]

[[textconv]]
pattern = "**/*.plist"
command = "/bin/zsh"
args = ["-c", "plutil -convert json -o - - | jq"]
